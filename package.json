{
  "name": "hrp-mcp",
  "version": "0.2.0-alpha",
  "private": true,
  "description": "Honest Response Protocol - MCP server for epistemic discipline in LLM responses",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "hrp-mcp": "build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "keywords": [
    "mcp",
    "llm",
    "honesty",
    "epistemics",
    "honesty-gap",
    "observer-architecture",
    "ai-safety",
    "claude",
    "nova"
  ],
  "files": [
    "build"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dartavion/honest-response-protocol.git"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}